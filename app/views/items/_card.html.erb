<div class="card bg-base-100 shadow">
  <div class="card-body">

    <div class="flex justify-between items-stretch">

      <!-- 左列 -->
      <div class="flex flex-1 min-w-0 flex-col">

        <!-- アイテム名 -->
        <h2 class="card-title truncate">
          <%= item.name %>
        </h2>

        <!-- アイテム登録日 -->
        <p class="text-sm text-gray-500 mt-1">
          登録日：<%= item.created_at.strftime("%Y/%-m/%-d") %>
        </p>

        <!-- ステータスバッジ + 次にできることを案内 -->
        <div class="mt-3 flex flex-col gap-1 sm:flex-row sm:items-center">
          <%= render 'items/status_badge', item: item %>
          <p class="text-xs text-gray-600"><%= item.next_action_message %></p>
        </div>
      </div>

      <!-- 右列 -->
      <div class="flex flex-col items-end h-full mt-1 gap-5">

        <!-- 次できるアクションに遷移するボタン -->
        <% case item.status %>
        <% when "thinking" %>
          <% if item.cooldown_not_selected? %>
            <%= link_to "クールダウン設定", "#", class: "btn btn-outline btn-sm" %>
          <% elsif item.ready_for_decision? %>
            <%= link_to "判断する", "#", class: "btn btn-outline btn-sm" %>
          <% end %>
        <% end %>

        <!-- アイテム詳細に遷移するボタン -->
        <%= link_to "詳細", items_path(item), class: "btn btn-outline btn-sm mt-auto" %>
      </div>
    </div>
  </div>
</div>